rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /fulfillment/{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email.lower() == "dieblind@gmail.com";
      allow read: if true; // Lulu needs to access these via public URL
    }
    match /{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.token.email.lower() == "dieblind@gmail.com";
    }
  }
}
